# ---------- LLM API 配置（必填）----------
open_code_go_api=
model=deepseek-v4-flash
base_url=https://opencode.ai/zen/go/v1

# ---------- 企业微信通知（可选）----------
# 不配也能跑，只是不会发通知给工程师
WECHAT_WEBHOOK=

# ---------- 钉钉通知（可选）----------
# 不配也能跑
DINGTALK_WEBHOOK=

# ---------- 钉钉 Stream 长连接（可选）----------
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=

# MySQL 数据库配置（第一阶段新增）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=你的密码
MYSQL_DATABASE=ops_agent
